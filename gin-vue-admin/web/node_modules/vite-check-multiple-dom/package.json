{
  "name": "vite-check-multiple-dom",
  "type": "module",
  "version": "0.2.1",
  "description": "Capture Vue <Transition> runtime warnings and show actionable overlay in Vite dev.",
  "keywords": [
    "azir",
    "vite",
    "vue",
    "vue-router",
    "router",
    "transition",
    "root",
    "validator"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsdown --config build.config.ts",
    "build:obfuscate": "tsdown --config build.config.ts && pnpm run obfuscate",
    "obfuscate": "node scripts/obfuscate.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json",
    "verify": "pnpm run build && attw --pack ."
  },
  "packageManager": "pnpm@10.14.0",
  "peerDependencies": {
    "vite": ">=4.0.0",
    "vue": ">=3.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@types/node": "^22.0.0",
    "javascript-obfuscator": "5.2.1",
    "publint": "^0.3.16",
    "rollup-plugin-obfuscator": "^1.1.0",
    "tsdown": "^0.14.2",
    "typescript": "^5.8.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0",
    "vue": "^3.0.0"
  }
}
