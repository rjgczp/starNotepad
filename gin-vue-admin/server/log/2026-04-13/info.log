t icon-bangzhu","isHighlight":true,"recordedAt":"2026-04-08T17:44:00+08:00"},{"ID":0,"CreatedAt":"0001-01-01T00:00:00Z","UpdatedAt":"0001-01-01T00:00:00Z","userID":null,"userName":null,"categoryID":null,"title":"校园困扰记录","content":"<p>近期，我的同桌持续对我表现出不友善的行为，包括言语和行动上的欺负，并时常施加压力，让我感到困扰和不安。</p>","isTop":false,"remind":false,"color":"#4e80ee","icon":"iconfont icon-coffee","isHighlight":false,"recordedAt":"2026-04-11T14:27:58+08:00"}],"deletedIds":[]}}
